#!/usr/bin/env bash

exec 2> >(logger -s -t $(basename $0))

set -e

for cont in $(ls /opt/server/docker)
do
    state=$(docker inspect $cont | jq ".[] .State.Health.Status" | sed 's/"//g')
    if [ $state != "healthy" && $state != "null" ]
    then
        systemctl restart docker@$cont.service
    fi
done

exit 0