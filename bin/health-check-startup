#!/usr/bin/env bash

exec 2> >(logger -s -t $(basename $0))

set -e

cont=$1

timeout=60
state=$(docker inspect $cont | jq ".[] .State.Health.Status" | sed 's/"//g')
while [ $state != "healthy" && $state != "null"]
do
    timeout=$((timeout-1))
    sleep 1s

    if [ $timeout -eq 0 ]
    then
        exit 1
    fi

    state=$(docker inspect $cont | jq ".[] .State.Health.Status" | sed 's/"//g')
done

exit 0