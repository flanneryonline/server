#!/usr/bin/env bash

exec 2> >(logger -s -t $(basename $0))

set -e

export DEBIAN_FRONTEND=noninteractive

use_sudo=
if [ $UID -ne 0 ]; then
    use_sudo="sudo"
fi

SERVER_INSTALL=${SERVER_INSTALL:-/opt/server}
. "$SERVER_INSTALL/environment"
. "$SERVER_INSTALL/include"

$use_sudo apt-get update -qq
$use_sudo apt-get upgrade -qq --no-install-recommends
$use_sudo apt-get dist-upgrade -qq --no-install-recommends
$use_sudo apt-get autoremove -qq

#server config update
if [ ! -d "$SERVER_INSTALL" ]
then
    $use_sudo git clone "$SERVER_GIT_LOCATION" "$SERVER_INSTALL"
    errorcheck && echoerr "failed to clone from git" && return 1
fi
pushd "$SERVER_INSTALL" >/dev/null
$use_sudo git rev-parse --git-dir >/dev/null 2>&1
errorcheck && popd >/dev/null && echoerr "directory not a git repo" && return 1
$use_sudo git remote update >/dev/null
errorcheck && popd >/dev/null && echoerr "failed to update git repo" && return 1
local_rev=$(git rev-parse master)
server_rev=$(git rev-parse origin/master)
if [ "$local_rev" != "$server_rev" ]
then
    $use_sudo git reset --hard origin/master >/dev/null
    errorcheck && popd >/dev/null && echoerr "failed to reset git" && return 1
fi
popd >/dev/null

#dotfiles update
if [ ! -d "/home/$ADMIN_USERNAME" ]
then
    $use_sudo git clone "$DOTFILE_GIT_LOCATION" "/home/$ADMIN_USERNAME"
    errorcheck && echoerr "failed to clone from git" && return 1
fi
pushd "/home/$ADMIN_USERNAME" >/dev/null
$use_sudo git rev-parse --git-dir >/dev/null 2>&1
errorcheck && popd >/dev/null && echoerr "directory not a git repo" && return 1
$use_sudo git remote update >/dev/null
errorcheck && popd >/dev/null && echoerr "failed to update git repo" && return 1
local_rev=$(git rev-parse master)
server_rev=$(git rev-parse origin/master)
if [ "$local_rev" != "$server_rev" ]
then
    $use_sudo git reset --hard origin/master >/dev/null
    errorcheck && popd >/dev/null && echoerr "failed to reset git" && return 1
fi
popd >/dev/null

for file in (ls $SECRETS_LOCATION); do
    echo "${file^^}=$(cat $SECRETS_LOCATION/$file)" | $use_sudo tee -a $SERVER_INSTALL/environment >/dev/null
done

# #stop all services
# for service in ($use_sudo /opt/server/bin/service-scripts/list-all-services)
# do
#     $use_sudo /opt/server/bin/sdstop $service
# done

# #daemon reload
# $use_sudo systemctl daemon-reload

# #start all services
# for service in ($use_sudo /opt/server/bin/service-scripts/list-all-services)
# do
#     $use_sudo /opt/server/bin/sdstart $service
# done



exit 0