#!/usr/bin/env bash

set -e

SERVER_INSTALL=${SERVER_INSTALL:-/opt/server}
. "$SERVER_INSTALL/environment"

docker pull thrnz/docker-wireguard-pia

# try removing SYS_MODULE and dev/net/tun
docker create -t \
--name=vpn \
--health-cmd="ping -c 1 www.google.com || exit 1" \
--health-interval=30s \
--health-start-period=10s \
--health-timeout=10s \
-p 5076:5076 \
-e LOC=us_toronto \
-e USER_FILE=/pia/creds/pia_user \
-e PASS_FILE=/pia/creds/pia_pass \
-e PORT_FORWARDING=1 \
--cap-add=NET_ADMIN \
--sysctl net.ipv4.conf.all.src_valid_mark=1 \
-v $STORAGE_CONFIG_DIR/vpn:/pia \
-v $STORAGE_CONFIG_DIR/vpn/shared:/pia-shared \
thrnz/docker-wireguard-pia